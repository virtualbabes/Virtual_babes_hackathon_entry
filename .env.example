# ==============================================================================
# Server Configuration
# ==============================================================================
# Standard PORT variable used by Render and Docker
PORT=8082

# Default network for stats lookup and onboarding (VOI or ALGO)
DEFAULT_NETWORK=VOI

# Local directory for persistent JSON caches and audit logs (Render Volume path)
DATA_DIR=./data

# Comma-separated list of allowed origins for CORS and WebSocket handshake.
# Include your Carrd production URL and localhost for testing.
ALLOWED_ORIGINS=https://yoursite.com,http://localhost:8082

# ==============================================================================
# Blockchain Nodes (Indexer & RPC)
# NOTE: In production, these should be high-availability RPCs like Nodly/LlamaRPC
# ==============================================================================
# Algorand Mainnet API (Required for Cross-chain metadata lookups)
ALGOD_URL_ALGO=https://mainnet-api.algonode.cloud
INDEXER_URL_ALGO=https://arc72-mainnet.nftnavigator.xyz/nft-indexer/v1

# Voi Mainnet API (Primary network for the Arena)
# To specify a custom port, use the format: http://hostname:port
ALGOD_URL_VOI=https://mainnet-api.voi.network
INDEXER_URL_VOI=https://arc72-voi-mainnet.nftnavigator.xyz/nft-indexer/v1

# ==============================================================================
# Game Economy & Assets
# ==============================================================================
# The official address holding the $VBV tokens for the faucet.
VAULT_ADDRESS=PLACEHOLDER_VAULT_ADDRESS_HERE
# The 24/25-word mnemonic for the VAULT_ADDRESS (Keep this extremely secure!)
FAUCET_MNEMONIC="word1 word2 word3 ... word25"

# Main ARC-72 Collection ID for Battle Cards (Virtualbabes NFT Collection)
COLLECTION_ID=7900471

# Primary Reward Asset ID ($VBV ARC-200 Contract)
REWARD_ASSET_ID=40227315
MAX_FAUCET_CAPACITY=10000

# The minimum native VOI balance required before an admin alert is triggered (e.g., 100.0)
VOI_GAS_THRESHOLD=100.0

# Algorand-side payment token for bridge buy-ins (e.g., $AVoi)
AVOI_ASSET_ID=2320775407
# Secondary/Fallback Asset ID for win tracking and historical aggregation
FALLBACK_REWARD_ASSET_ID=0

# Base amount of reward per win (in whole units, e.g., 5.0 $VBV)
BASE_REWARD=5.0

# Minimum reputation required to trigger the 10% loyalty bonus payout
MIN_REPUTATION_FOR_REWARD=500

# ==============================================================================
# Administrative Security
# ==============================================================================
# Secret key for legacy admin API access (X-Admin-Key fallback)
ADMIN_KEY=LEGACY_FALLBACK_KEY_DO_NOT_USE_FOR_SIGNATURES

# Comma-separated list of authorized admin wallet addresses for signature auth
ADMIN_WALLETS=ADMIN_VOI_WALLET_1,ADMIN_VOI_WALLET_2

# ==============================================================================
# Frontend / Client Configuration
# ==============================================================================
# WalletConnect Project ID (Obtain from https://cloud.walletconnect.com)
WC_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID_HERE

# Voi Network Chain ID
VOI_CHAIN_ID=algorand:wGHE2Pwd1-YdV4EuJFy9u6C24-L-2B05
ALGO_CHAIN_ID=algorand:mainnet-v1.0
ETH_CHAIN_ID=eip155:1

# ==============================================================================
# Development & Testing
# ==============================================================================
ARENA_STRESS_TEST=false